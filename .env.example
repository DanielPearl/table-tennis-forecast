# Table Tennis Forecast — environment template.
# Copy to `.env` for local dev. Never commit `.env`.
#
# IMPORTANT: KALSHI_API_KEY_ID and KALSHI_PRIVATE_KEY_PATH are loaded
# from the shared /root/gas-prices/.env on the droplet (the systemd
# units list both EnvironmentFiles). Do NOT add empty
# ``KALSHI_API_KEY_ID=`` lines here — systemd loads .env files in order
# and a later empty assignment overrides the shared value.
# Only add per-project secrets / overrides below.

# --- Optional: pre-match odds source ---
# https://the-odds-api.com — used only by the historical odds-pull
# script. The live monitor uses Kalshi prices directly.
THE_ODDS_API_KEY=

# Dashboard binding (when running the standalone table-tennis dashboard).
HOST=0.0.0.0
PORT=8091
