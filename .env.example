# Table Tennis Forecast — environment template.
# Copy to `.env` for local dev. Never commit `.env`.

# --- REQUIRED: Kalshi API credentials ---
# The live monitor reads table-tennis markets (KXATTABLE / KXTABLETENNIS
# / KXWTTSGLES — whichever series Kalshi publishes) via the kalshi_sdk.
# Without these the bot has no markets to forecast against.
# On the droplet these come from /root/gas-prices/.env (shared creds).
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# --- Optional: pre-match odds source ---
# https://the-odds-api.com — used only by the historical odds-pull
# script. The live monitor uses Kalshi prices directly.
THE_ODDS_API_KEY=

# Dashboard binding (when running the standalone table-tennis dashboard).
HOST=0.0.0.0
PORT=8091
